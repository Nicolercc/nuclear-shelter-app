# Copy to `.env` (never commit real keys).

PORT=3001

# When set, serves the built SPA from this directory (production Docker image uses /app/public).
# STATIC_DIR=

# Comma-separated browser origins allowed to call the API. Leave unset to allow any origin (dev only).
# CORS_ORIGIN=http://localhost:3000

OPENWEATHER_API_KEY=
GOOGLE_MAPS_KEY=

LOG_LEVEL=info
